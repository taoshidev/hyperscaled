# =============================================================================
# Hyperscaled — example environment
# =============================================================================
# Copy to .env.local for local dev. Every variable actually read by the code
# is enumerated here. See README.md "Environment" for full descriptions and
# which are required vs optional in production.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
USE_TESTNET=true

# Public origin of this app. Used by SEO, sitemap, OpenGraph, and absolute
# URL helpers. Override per-environment (dev / preview / prod).
HYPERSCALED_BASE_URL=http://localhost:4568

# Same value, exposed to the browser bundle (used by lib/brand.jsx).
NEXT_PUBLIC_HYPERSCALED_BASE_URL=http://localhost:4568

# Default miner slug used when registration UX has not picked one yet.
DEFAULT_MINER_SLUG=vanta

# -----------------------------------------------------------------------------
# x402 / Coinbase CDP facilitator (Base mainnet payments)
# -----------------------------------------------------------------------------
# Required when USE_TESTNET=false. The Base mainnet x402 facilitator at
# https://api.cdp.coinbase.com is authenticated, so verify+settle calls on
# /api/register need a CDP API key. Provision one at
# https://portal.cdp.coinbase.com → API Keys (server-side, NOT client-side).
# Server-only — never expose to the browser bundle.
#
# When USE_TESTNET=true these are ignored — the public x402 testnet
# facilitator (https://x402.org/facilitator) doesn't require auth.
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# -----------------------------------------------------------------------------
# Public on-chain constants (safe in browser bundle)
# -----------------------------------------------------------------------------
# Hyperliquid builder code address. Leave blank to skip approveBuilderFee.
NEXT_PUBLIC_HYPERSCALED_BUILDER_ADDRESS=

# Receiving wallet for USDC registration payments. Read only by lib/db/seed.mjs
# at seed time and written into entity_miners.usdc_wallet for the Vanta row.
# The UI reads the wallet at runtime from /api/miners/<slug>; this value is
# never bundled to the client.
HYPERSCALED_USDC_WALLET=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local Postgres (Homebrew or system install) on the standard port 5432,
# matching the vanta-ui setup. Create the database once:  createdb hyperscaled
#
# When connecting via Cloud SQL Auth Proxy (e.g. running migrations against the
# dev DB through a local proxy on 127.0.0.1:5432), append ?sslmode=disable —
# the proxy terminates TLS upstream and doesn't speak SSL on the local hop.
# Harmless against a plain local Postgres.
DATABASE_URL=postgresql://localhost:5432/hyperscaled?sslmode=disable

# Cloud SQL Connector path (production). When set, DATABASE_URL is ignored
# and the pool is built from these values via @google-cloud/cloud-sql-connector.
# GCP_SERVICE_ACCOUNT_B64=base64-of-service-account.json
# CLOUD_SQL_INSTANCE_CONNECTION_NAME=project:region:instance
# DB_USER=hyperscaled
# DB_PASSWORD=
# DB_NAME=hyperscaled

# -----------------------------------------------------------------------------
# Validator (the Vanta enforcement layer this app proxies)
# -----------------------------------------------------------------------------
# Local dev shares the testnet validator that vanta-ui also points at.
# Production: https://validator.mainnet.vantatrading.io
VALIDATOR_API_URL=https://validator.testnet.vantatrading.io

# Server-only bearer for privileged validator paths. Required for
# /api/dashboard stats & ledger pulls and /api/dashboard/payout. Never
# expose this to the client bundle.
VALIDATOR_API_KEY=

# -----------------------------------------------------------------------------
# Entity miner gateways
# -----------------------------------------------------------------------------
# Optional fallback API key when entity_miners.api_key is empty in the DB.
# Per-slug overrides take precedence (ENTITY_MINER_API_KEY_<UPPER_SLUG>).
# ENTITY_MINER_API_KEY=
# ENTITY_MINER_API_KEY_VANTA=

# Skip the post-registration call to the miner gateway's create-hl-subaccount
# endpoint. Useful when running without a real miner.
# SKIP_ENTITY_MINER_CALL=true

# Returns deterministic stub data for entity miner gateway calls
# (lib/gateway-stubs.js). Useful for offline UI dev.
# STUB_GATEWAY=true

# Used only by lib/db/seed.mjs when writing the "vanta" row.
# VANTA_API_KEY=

# -----------------------------------------------------------------------------
# Server-side admin / cron secrets (required in production)
# -----------------------------------------------------------------------------
# HMAC secret used to sign /command-center session cookies. Must be at least
# 32 chars in production; rotating invalidates all active admin sessions.
COMMAND_CENTER_SESSION_SECRET=local-command-center-secret-replace-me-32chars

# Optional second factor after wallet SIWE for /command-center. When set to a
# non-empty value, successful wallet sign-in only unlocks `/command-center/security-token`;
# staff must submit this exact secret before `requireCommandCenterStaff` allows
# protected pages or export APIs.
# COMMAND_CENTER_SECURITY_TOKEN=

# Comma-separated EVM addresses seeded into command_center_staff by
# `pnpm db:seed`. Anyone listed here can sign in to /command-center after the
# wallet signs the SIWE-style nonce; everyone else sees a 404. Optional admin
# label may be appended after a colon. Append `:super_admin` to grant the
# super-admin role; default role is `admin`.
# COMMAND_CENTER_STAFF_WALLETS=0xAbC...:Alice,0xDef...:Bob:super_admin

# -----------------------------------------------------------------------------
# Affiliate attribution
# -----------------------------------------------------------------------------
# HMAC secret used to sign the `hs_attr` first-touch attribution cookie. Must
# be at least 32 chars. Rotation invalidates every visitor's pending
# attribution; existing attribution rows on referral_attributions persist.
# Falls back to COMMAND_CENTER_SESSION_SECRET when unset, but a dedicated
# secret is recommended so command-center session and visitor cookies can
# rotate independently.
ATTRIBUTION_COOKIE_SECRET=local-attribution-secret-replace-me-32chars

# Salt added to client IP before SHA-256 hashing in /api/track/click. Visitor
# IPs are never stored in plaintext; the salted, truncated hash is used only
# for de-duplicating bot floods within the same network. REQUIRED in
# production (>= 16 chars). When missing in NODE_ENV=production the route
# refuses to write the IP hash at all rather than fall back to a public salt.
# ATTRIBUTION_IP_SALT=

# Bearer token for GET /api/sync-registrations (Vercel cron).
CRON_SECRET=local-cron-secret

# Bearer token for POST /api/register/retry.
RETRY_SECRET=local-retry-secret

# Bearer token for POST /api/vanta-sync (back-office sync hook).
VANTA_SYNC_API_KEY=local-sync-key

# Optional: override the per-job time budget (ms) on /api/sync-registrations.
# SYNC_BUDGET_MS=55000

# When "true" /api/testnet-register is enabled. Default is disabled.
# Never enable in production.
# ENABLE_TESTNET_REGISTER=true
# TESTNET_REGISTER_SECRET=long-random-string-required-when-enabled

# -----------------------------------------------------------------------------
# Dev-only economic helpers
# -----------------------------------------------------------------------------
# Comma-separated EVM addresses that pay $0.01 instead of full price.
# NEVER set this in production.
# DEV_TEST_WALLETS=0x1234...abcd,0x5678...efgh

# -----------------------------------------------------------------------------
# Sumsub KYC
# -----------------------------------------------------------------------------
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=
SUMSUB_LEVEL_NAME=basic-kyc-level

# -----------------------------------------------------------------------------
# Affiliate tracking (Tolt)
# -----------------------------------------------------------------------------
TOLT_API_KEY=

# -----------------------------------------------------------------------------
# HubSpot (registration email capture — Vanta & Hyperscaled only)
# -----------------------------------------------------------------------------
# Embedded form + Forms API on "Continue to review" when both are set.
# Omit or leave blank to use the default email field without HubSpot.
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_HUBSPOT_FORM_ID=

# Waitlist form shown on the tier-selection page when a registration cap
# below has been reached. Same portal as above; supply a separate form id
# so opt-ins are tagged distinctly in HubSpot. When unset the tier page
# falls back to a plain "registrations are paused" message.
NEXT_PUBLIC_HUBSPOT_WAITLIST_FORM_ID=

# -----------------------------------------------------------------------------
# Phased onboarding (registration caps)
# -----------------------------------------------------------------------------
# Cap the number of free ($0) and paid (>$0) registrations independently.
# Leave blank or unset to disable the corresponding cap (no limit).
# Note: setting "0" means a cap of zero signups (instantly full), not
# "unlimited". Use blank/unset to turn caps off entirely.
#
#  - Free  → counts rows with price_usdc = 0 and status <> 'failed'
#            (includes pending + registered, so in-flight signups
#             consume a slot).
#  - Paid  → counts rows with price_usdc > 0 and status = 'registered'
#            (only completed paid signups consume a slot).
#
# When a cap is reached the tier-selection page renders a HubSpot waitlist
# (configured above) and /api/register/preflight + /api/register reject with
# 403 + a stable code (REGISTRATION_FREE_CAP / REGISTRATION_PAID_CAP).
REGISTRATION_FREE_MAX=
REGISTRATION_PAID_MAX=

# -----------------------------------------------------------------------------
# Email (transactional via SMTP / Nodemailer)
# -----------------------------------------------------------------------------
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SLACK_ERROR_WEBHOOK_URL=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Vercel injects VERCEL_GIT_COMMIT_SHA server-side. Mirror it to the client
# so browser Sentry can tag releases.
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=

# -----------------------------------------------------------------------------
# Operations scripts (NOT loaded by the Next.js app)
# Set these only on the ops machine running scripts/refund.mjs etc.
# -----------------------------------------------------------------------------
# BASE_RPC_URL=https://mainnet.base.org
# REFUND_PRIVATE_KEY=
# VALIDATOR_ADMIN_API_KEY=

# =============================================================================
# Hyperscaled — example environment
# =============================================================================
# Copy to .env.local for local dev. Every variable actually read by the code
# is enumerated here. See README.md "Environment" for full descriptions and
# which are required vs optional in production.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
USE_TESTNET=true

# Public origin of this app. Used by SEO, sitemap, OpenGraph, and absolute
# URL helpers. Override per-environment (dev / preview / prod).
HYPERSCALED_BASE_URL=http://localhost:4568

# Same value, exposed to the browser bundle (used by lib/brand.jsx).
NEXT_PUBLIC_HYPERSCALED_BASE_URL=http://localhost:4568

# Default miner slug used when registration UX has not picked one yet.
DEFAULT_MINER_SLUG=vanta

# -----------------------------------------------------------------------------
# Public on-chain constants (safe in browser bundle)
# -----------------------------------------------------------------------------
# Hyperliquid builder code address. Leave blank to skip approveBuilderFee.
NEXT_PUBLIC_HYPERSCALED_BUILDER_ADDRESS=

# Receiving wallet for USDC registration payments. Read only by lib/db/seed.mjs
# at seed time and written into entity_miners.usdc_wallet for the Vanta row.
# The UI reads the wallet at runtime from /api/miners/<slug>; this value is
# never bundled to the client.
HYPERSCALED_USDC_WALLET=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local Postgres (Homebrew or system install) on the standard port 5432,
# matching the vanta-ui setup. Create the database once:  createdb hyperscaled
DATABASE_URL=postgresql://localhost:5432/hyperscaled

# When connecting to a managed Postgres in production, supply the CA bundle.
# Set ONE of these two; the second takes a filesystem path and reads on boot.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n…\n-----END CERTIFICATE-----"
# DATABASE_CA_CERT_PATH=/etc/ssl/certs/postgres-ca.pem

# Dev/CI escape hatch — when "true" the pool will set rejectUnauthorized=false.
# Never set this in production.
# DATABASE_SSL_INSECURE=true

# Cloud SQL Connector path (production). When set, DATABASE_URL is ignored.
# GCP_SERVICE_ACCOUNT_B64=base64-of-service-account.json
# CLOUD_SQL_INSTANCE_CONNECTION_NAME=project:region:instance
# DB_USER=hyperscaled
# DB_PASSWORD=
# DB_NAME=hyperscaled

# -----------------------------------------------------------------------------
# Validator (the Vanta enforcement layer this app proxies)
# -----------------------------------------------------------------------------
# Local dev shares the testnet validator that vanta-ui also points at.
# Production: https://validator.mainnet.vantatrading.io
VALIDATOR_API_URL=http://34.187.154.219:48888

# Server-only bearer for privileged validator paths. Required for
# /api/dashboard stats & ledger pulls and /api/dashboard/payout. Never
# expose this to the client bundle.
VALIDATOR_API_KEY=

# -----------------------------------------------------------------------------
# Entity miner gateways
# -----------------------------------------------------------------------------
# Optional fallback API key when entity_miners.api_key is empty in the DB.
# Per-slug overrides take precedence (ENTITY_MINER_API_KEY_<UPPER_SLUG>).
# ENTITY_MINER_API_KEY=
# ENTITY_MINER_API_KEY_VANTA=

# Skip the post-registration call to the miner gateway's create-hl-subaccount
# endpoint. Useful when running without a real miner.
# SKIP_ENTITY_MINER_CALL=true

# Returns deterministic stub data for entity miner gateway calls
# (lib/gateway-stubs.js). Useful for offline UI dev.
# STUB_GATEWAY=true

# Used only by lib/db/seed.mjs when writing the "vanta" row.
# VANTA_API_KEY=

# -----------------------------------------------------------------------------
# Server-side admin / cron secrets (required in production)
# -----------------------------------------------------------------------------
# Bearer token for GET /api/sync-registrations (Vercel cron).
CRON_SECRET=local-cron-secret

# Bearer token for POST /api/register/retry.
RETRY_SECRET=local-retry-secret

# Bearer token for POST /api/vanta-sync (back-office sync hook).
VANTA_SYNC_API_KEY=local-sync-key

# Optional: override the per-job time budget (ms) on /api/sync-registrations.
# SYNC_BUDGET_MS=55000

# Required for POST /api/register/preflight when ENABLE_PREFLIGHT_AUTH=true.
# Generated by ops; rotate quarterly.
PREFLIGHT_SECRET=

# When "true" /api/register/preflight rejects requests without a matching
# bearer token. Defaults to false in dev so the wizard works locally.
# ENABLE_PREFLIGHT_AUTH=true

# When "true" /api/testnet-register is enabled. Default is disabled.
# Never enable in production.
# ENABLE_TESTNET_REGISTER=true
# TESTNET_REGISTER_SECRET=long-random-string-required-when-enabled

# -----------------------------------------------------------------------------
# Dev-only economic helpers
# -----------------------------------------------------------------------------
# Comma-separated EVM addresses that pay $0.01 instead of full price.
# NEVER set this in production.
# DEV_TEST_WALLETS=0x1234...abcd,0x5678...efgh

# -----------------------------------------------------------------------------
# Sumsub KYC
# -----------------------------------------------------------------------------
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=
SUMSUB_LEVEL_NAME=basic-kyc-level

# -----------------------------------------------------------------------------
# Affiliate tracking (Tolt)
# -----------------------------------------------------------------------------
TOLT_API_KEY=

# -----------------------------------------------------------------------------
# Email (transactional via SMTP / Nodemailer)
# -----------------------------------------------------------------------------
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SLACK_ERROR_WEBHOOK_URL=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Vercel injects VERCEL_GIT_COMMIT_SHA server-side. Mirror it to the client
# so browser Sentry can tag releases.
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=

# -----------------------------------------------------------------------------
# Edge rate limiting (Upstash) — used by lib/rate-limit.js when configured.
# Falls back to an in-process limiter for local dev when these are unset.
# -----------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Operations scripts (NOT loaded by the Next.js app)
# Set these only on the ops machine running scripts/refund.mjs etc.
# -----------------------------------------------------------------------------
# BASE_RPC_URL=https://mainnet.base.org
# REFUND_PRIVATE_KEY=
# VALIDATOR_ADMIN_API_KEY=

{
  "name": "hyperscaled_site",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "dev": "next dev -p 4568",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest --config vitest.config.js",
    "e2e": "pnpm exec playwright test",
    "e2e:ui": "pnpm exec playwright test --ui",
    "e2e:debug": "pnpm exec playwright test --debug",
    "e2e:headless": "pnpm exec playwright test --headed",
    "e2e:install": "pnpm exec playwright install --with-deps chromium",
    "e2e:report": "pnpm exec playwright show-report",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node --env-file-if-exists=.env.local lib/db/seed.mjs",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@coinbase/x402": "2.1.0",
    "@google-cloud/cloud-sql-connector": "1.9.1",
    "@phosphor-icons/react": "2.1.10",
    "@polkadot/keyring": "14.0.1",
    "@polkadot/util": "14.0.2",
    "@polkadot/util-crypto": "14.0.2",
    "@rainbow-me/rainbowkit": "2.2.10",
    "@sentry/nextjs": "10.45.0",
    "@sumsub/websdk-react": "2.6.1",
    "@tailwindcss/postcss": "4.2.1",
    "@tanstack/react-query": "5.90.21",
    "@x402/core": "2.5.0",
    "@x402/evm": "2.5.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "framer-motion": "12.37.0",
    "google-auth-library": "10.6.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "0.575.0",
    "next": "15.5.15",
    "nodemailer": "8.0.5",
    "pg": "8.19.0",
    "postcss": "8.5.6",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "3.8.5",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "1.4.0",
    "viem": "2.46.3",
    "wagmi": "2.19.5"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@playwright/test": "1.59.1",
    "@types/pg": "8.18.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.3",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "16.5.0",
    "tsx": "4.20.6",
    "vitest": "2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "@next/swc-darwin-arm64",
      "@next/swc-darwin-x64",
      "@next/swc-linux-x64-gnu",
      "@next/swc-linux-arm64-gnu",
      "esbuild",
      "keccak",
      "sharp"
    ]
  }
}
